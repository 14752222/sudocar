<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#CC000000"
    android:padding="40dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 快速切换"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 1"
            android:textColor="#4FC3F7"
            android:textSize="16sp"
            android:layout_marginStart="20dp" />

        <!-- 关闭按钮 -->
        <LinearLayout
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginStart="40dp"
            android:background="?attr/selectableItemBackgroundBorderless">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ 关闭"
                android:textColor="#888888"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 应用卡片区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp">

        <!-- 左边预览 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_left"
            android:layout_width="160dp"
            android:layout_height="180dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="#2A2A3E"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_icon_left"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tv_name_left"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="应用名"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 中间选中 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_center"
            android:layout_width="200dp"
            android:layout_height="220dp"
            android:layout_marginHorizontal="10dp"
            app:cardBackgroundColor="#4FC3F7"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/iv_icon_center"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tv_name_center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="应用名"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ 点击确认"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 右边预览 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_right"
            android:layout_width="160dp"
            android:layout_height="180dp"
            android:layout_marginStart="20dp"
            app:cardBackgroundColor="#2A2A3E"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_icon_right"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tv_name_right"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="应用名"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 底部提示 -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="◀ 左右键切换 | OK键确认启动 | 5秒无操作自动关闭"
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginTop="30dp"
        android:gravity="center" />

</LinearLayout>
