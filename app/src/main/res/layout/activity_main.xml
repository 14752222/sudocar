<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 左侧 Fragment 容器 (固定 10%) -->
    <FrameLayout
        android:id="@+id/container_left"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/container_bottom"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.1" />

    <!--
      中间 Fragment 容器
      初始状态：在 Left 和 Right 之间，宽度大 (0.68)
      注意：必须设置 width_default="percent"
    -->
    <FrameLayout
        android:id="@+id/container_middle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toEndOf="@id/container_left"
        app:layout_constraintEnd_toStartOf="@id/container_right"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/container_bottom"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.68" />

    <!--
      右侧 Fragment 容器
      初始状态：在 Middle 和 Parent 之间，宽度小 (0.22)
      注意：必须设置 width_default="percent"
    -->
    <FrameLayout
        android:id="@+id/container_right"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toEndOf="@id/container_middle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/container_bottom"
        android:background="@color/black"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.22" />

    <!-- 底部 Fragment 容器 -->
    <FrameLayout
        android:id="@+id/container_bottom"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>