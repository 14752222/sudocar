<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/bottom_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 左侧：设置 + 切换 + 夜间模式（靠近驾驶员） -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 设置按钮 -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="设置"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <!-- 切换按钮 -->
        <Button
            android:id="@+id/btn_swap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="切换"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/btn_bg"
            android:textSize="12sp"
            android:minWidth="56dp" />

        <!-- 夜间模式按钮（靠近驾驶员） -->
        <ImageButton
            android:id="@+id/btn_night_mode"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:src="@android:drawable/ic_menu_day"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="夜间模式"
            android:scaleType="centerInside"
            android:padding="10dp" />
    </LinearLayout>

    <!-- 中间：时间 + 空调 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginHorizontal="8dp">

        <!-- 时间 -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 空调状态 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_ac_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="空调: 关"
                android:textColor="@color/ac_off"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_ac_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" --°C"
                android:textColor="@color/ac_temp"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 右侧：快捷应用 + 占位 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 快捷应用按钮 -->
        <ImageButton
            android:id="@+id/btn_quick_app"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="快捷应用"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <!-- 占位，保持平衡 -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

</LinearLayout>
